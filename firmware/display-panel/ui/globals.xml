<globals>
  <consts>
    <color name="color_bg" value="0x14181f"/>
    <color name="color_panel" value="0x1f2530"/>
    <color name="color_text_primary" value="0xf5f6f8"/>
    <color name="color_text_muted" value="0x8b93a3"/>
    <color name="color_accent" value="0x4da3ff"/>
    <color name="color_warn" value="0xff9f43"/>
    <color name="color_alert" value="0xff5c5c"/>
    <color name="color_ok" value="0x3ddc97"/>

    <px name="screen_w" value="800"/>
    <px name="screen_h" value="480"/>

    <!-- Weather condition icon glyphs (weather_icons_48 font) -->
    <string name="icon_sun" value="&#xf00d;"/>
    <string name="icon_clouds" value="&#xf013;"/>
    <string name="icon_rain" value="&#xf019;"/>
    <string name="icon_snow" value="&#xf01b;"/>
    <string name="icon_thunderstorm" value="&#xf01e;"/>
    <string name="icon_wind" value="&#xf050;"/>
  </consts>

  <fonts>
    <bin name="montserrat_20" src_path="fonts/Montserrat-Medium.ttf" size="20" bpp="4" as_file="false"/>
    <bin name="montserrat_28" src_path="fonts/Montserrat-Medium.ttf" size="28" bpp="4" as_file="false"/>
    <bin name="montserrat_40" src_path="fonts/Montserrat-Medium.ttf" size="40" bpp="4" as_file="false" symbols="°"/>
    <bin name="montserrat_48" src_path="fonts/Montserrat-Medium.ttf" size="48" bpp="4" as_file="false"/>

    <!-- Weather condition glyphs: sun, clouds, rain, snow, wind, thunderstorm (see erikflowers/weather-icons) -->
    <bin name="weather_icons_48" src_path="fonts/weathericons-regular-webfont.ttf" size="48" bpp="4" as_file="false"
         range="0xf00d-0xf00d,0xf013-0xf013,0xf019-0xf019,0xf01b-0xf01b,0xf01e-0xf01e,0xf050-0xf050"/>
  </fonts>
</globals>
