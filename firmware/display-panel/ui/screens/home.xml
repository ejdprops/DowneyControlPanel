<screen>
  <view width="800" height="480" style_bg_color="#color_bg" style_pad_all="0">

    <!-- Top status bar: clock + date on the left, weather on the right -->
    <lv_obj x="0" y="0" width="800" height="140" style_bg_color="#color_bg" style_border_width="0"
            flex_flow="row" style_flex_main_place="space_between" style_pad_all="24">

      <lv_obj width="400" height="content" style_bg_opa="0" style_border_width="0"
              flex_flow="column">
        <lv_label name="clock_time" text="10:42 AM" style_text_color="#color_text_primary" style_text_font="montserrat_48"/>
        <lv_label name="clock_date" text="Saturday, July 11" style_text_color="#color_text_muted" style_text_font="montserrat_20"/>
      </lv_obj>

      <lv_obj name="weather_area" width="content" height="content" style_bg_opa="0" style_border_width="0"
              flex_flow="row" style_flex_cross_place="center">

        <lv_label name="weather_icon" text="#icon_clouds" style_text_color="#color_accent" style_text_font="weather_icons_48"/>

        <lv_obj width="content" height="content" style_bg_opa="0" style_border_width="0"
                flex_flow="column" style_pad_left="16">

          <lv_label name="weather_temp" text="72°F" style_text_color="#color_text_primary" style_text_font="montserrat_40"/>
          <lv_label name="weather_cond" text="Cloudy" style_text_color="#color_text_muted" style_text_font="montserrat_20"/>

          <lv_obj width="content" height="content" style_bg_opa="0" style_border_width="0"
                  flex_flow="row" style_pad_top="4">
            <lv_label name="weather_high" text="H: 78°" style_text_color="#color_text_primary" style_text_font="montserrat_20"/>
            <lv_label name="weather_low" text="L: 61°" style_text_color="#color_text_muted" style_text_font="montserrat_20" style_pad_left="16"/>
          </lv_obj>

        </lv_obj>
      </lv_obj>

    </lv_obj>

    <!-- Middle banner: outstanding med reminders, hidden when nothing is due -->
    <lv_obj name="reminder_banner" x="24" y="156" width="752" height="64"
            style_bg_color="#color_warn" style_radius="12" style_pad_all="16"
            flex_flow="row" style_flex_cross_place="center">
      <lv_label name="reminder_text" text="Evan: midday dose not yet taken"
                style_text_color="#color_bg" style_text_font="montserrat_20"/>
    </lv_obj>

    <!-- Bottom nav row: three big touch targets -->
    <lv_obj x="24" y="248" width="752" height="200" style_bg_opa="0" style_border_width="0"
            flex_flow="row" style_flex_main_place="space_between">

      <lv_button name="btn_timer" width="232" height="200" style_bg_color="#color_panel" style_radius="16"
                 flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center" style_pad_row="12">
        <lv_label text="#icon_clock" style_text_color="#color_accent" style_text_font="icons_48"/>
        <lv_label text="Timer" style_text_color="#color_text_primary" style_text_font="montserrat_28"/>
      </lv_button>

      <lv_button name="btn_meds" width="232" height="200" style_bg_color="#color_panel" style_radius="16"
                 flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center" style_pad_row="12">
        <lv_label text="#icon_pills" style_text_color="#color_accent" style_text_font="icons_48"/>
        <lv_label text="Meds" style_text_color="#color_text_primary" style_text_font="montserrat_28"/>
      </lv_button>

      <lv_button name="btn_home_controls" width="232" height="200" style_bg_color="#color_panel" style_radius="16"
                 flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center" style_pad_row="12">
        <lv_label text="#icon_house" style_text_color="#color_accent" style_text_font="icons_48"/>
        <lv_label text="Home" style_text_color="#color_text_primary" style_text_font="montserrat_28"/>
      </lv_button>

    </lv_obj>

  </view>
</screen>
